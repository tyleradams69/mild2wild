# Public canonical URL used by sitemap, robots.txt, canonical tags, and JSON-LD.
# Set this to the final production domain after buying/connecting the domain.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional local SEO fields. Fill these in before/when the Google Business Profile goes live.
NEXT_PUBLIC_BUSINESS_NAME="Mild 2 Wild"
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=
NEXT_PUBLIC_BUSINESS_STREET_ADDRESS=
NEXT_PUBLIC_BUSINESS_CITY=
NEXT_PUBLIC_BUSINESS_REGION=OH
NEXT_PUBLIC_BUSINESS_POSTAL_CODE=
NEXT_PUBLIC_BUSINESS_COUNTRY=US
NEXT_PUBLIC_BUSINESS_LATITUDE=
NEXT_PUBLIC_BUSINESS_LONGITUDE=

# Optional social profile URLs for LocalBusiness sameAs schema.
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TIKTOK_URL=
